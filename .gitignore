# 대용량 시뮬레이션 산출물 (repo 외부 /data/ 경로에 보관)
*.mot
*.sto
*.osim
*.mp4
*.pkl
*.npy

# 결과 이미지 — 기본 제외, docs/images/ 및 docs/figures/ 재귀 하위 예외 허용
*.png
!opensim_analysis/*/docs/images/**/*.png
!opensim_analysis/*/docs/figures/**/*.png
# Top-level docs/images/*.png (sub-dirless) 도 허용
!opensim_analysis/*/docs/images/*.png
!opensim_analysis/*/docs/figures/*.png

# Python
__pycache__/
*.pyc
.pytest_cache/
.ipynb_checkpoints/

# 환경
.env
*.log

# Moco external kill-switch file
delete_this_to_stop_optimization*
